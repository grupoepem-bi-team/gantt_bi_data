# ===========================================
# Docker Production Environment
# ===========================================

# PostgreSQL
POSTGRES_USER=gantt_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=gantt_db
POSTGRES_PORT=5432

# API
API_PORT=3000
DATABASE_URL=postgresql://gantt_user:your_secure_password_here@db:5432/gantt_db
NODE_ENV=production
JWT_SECRET=gantt-bi-epem-jwt-secret-change-in-production-2026

# Frontend
APP_PORT=8080

# CORS
CORS_ORIGIN=http://localhost:8080