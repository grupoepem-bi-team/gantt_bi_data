# ===========================================
# Docker Production Environment
# ===========================================

# PostgreSQL
POSTGRES_USER=gantt_user
POSTGRES_PASSWORD=CHANGE_ME_to_a_strong_password
POSTGRES_DB=gantt_db
POSTGRES_PORT=5432

# API
API_PORT=3000
DATABASE_URL=postgresql://gantt_user:CHANGE_ME_to_a_strong_password@db:5432/gantt_db
NODE_ENV=production
JWT_SECRET=CHANGE_ME_to_a_random_64_char_string
CORS_ORIGIN=http://localhost:8080

# Initial user passwords (only used on first DB seed)
ADMIN_INITIAL_PASSWORD=CHANGE_ME_strong_admin_password
JEAN_INITIAL_PASSWORD=CHANGE_ME_random_password_1
JESUS_INITIAL_PASSWORD=CHANGE_ME_random_password_2

# Frontend
APP_PORT=8080