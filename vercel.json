{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.ts"
    },
    {
      "src": "/api/users/login",
      "dest": "/api/users/login.ts"
    },
    {
      "src": "/api/users",
      "dest": "/api/users.ts"
    },
    {
      "src": "/api/rows/(?<id>[^/]+)",
      "dest": "/api/rows/[id].ts"
    },
    {
      "src": "/api/rows",
      "dest": "/api/rows.ts"
    },
    {
      "src": "/api/items/(?<id>[^/]+)",
      "dest": "/api/items/[id].ts"
    },
    {
      "src": "/api/items",
      "dest": "/api/items.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://${VERCEL_URL}"
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}